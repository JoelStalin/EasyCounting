APP_NAME=DGII e-CF API
ENVIRONMENT=development

DATABASE_URL=postgresql+asyncpg://dgii:dgii@db:5432/dgii
DB_URL=postgresql+asyncpg://dgii:dgii@db:5432/dgii
REDIS_URL=redis://redis:6379/0

CORS_ALLOW_ORIGINS=https://api.getupsoft.com.do,https://admin.getupsoft.com.do,https://cliente.getupsoft.com.do,http://api.getupsoft.com.do,http://admin.getupsoft.com.do,http://cliente.getupsoft.com.do,http://localhost:8080,http://localhost:5173,http://localhost:5174
RATE_LIMIT_PER_MINUTE=100

# Dominios de portales (se utilizan para CORS por defecto)
CLIENT_PORTAL_DOMAIN=cliente.getupsoft.com.do
ADMIN_PORTAL_DOMAIN=admin.getupsoft.com.do
PARTNER_PORTAL_DOMAIN=socios.getupsoft.com.do
PUBLIC_SITE_DOMAIN=www.getupsoft.com.do

# Tours autoguiados
UI_TOURS_ENABLED=true
UI_TOURS_DEFAULT_AUTORUN=true

# Social auth (Google/Facebook/Apple)
SOCIAL_AUTH_ENABLED=false
SOCIAL_AUTH_BASE_URL=https://api.getupsoft.com.do
SOCIAL_AUTH_SESSION_SECRET=CHANGE_ME_SOCIAL_SESSION

SOCIAL_GOOGLE_ENABLED=false
SOCIAL_GOOGLE_CLIENT_ID=
SOCIAL_GOOGLE_CLIENT_SECRET=

SOCIAL_FACEBOOK_ENABLED=false
SOCIAL_FACEBOOK_CLIENT_ID=
SOCIAL_FACEBOOK_CLIENT_SECRET=

SOCIAL_APPLE_ENABLED=false
SOCIAL_APPLE_CLIENT_ID=
SOCIAL_APPLE_TEAM_ID=
SOCIAL_APPLE_KEY_ID=
SOCIAL_APPLE_PRIVATE_KEY=
SOCIAL_APPLE_PRIVATE_KEY_PATH=

# SMTP modular para notificaciones y workflows internos
# Opción 1: Mailpit (Open Source - Docker) - RECOMENDADO PARA DESARROLLO
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM=noreply@getupsoft.com.do
SMTP_TIMEOUT_SECONDS=20

# Nota: Para usar servicios externos en vez de Mailpit:
# SendGrid: SMTP_HOST=smtp.sendgrid.net SMTP_PORT=587 SMTP_USER=apikey SMTP_PASS=SG.xxx
# Gmail: SMTP_HOST=smtp.gmail.com SMTP_PORT=587 SMTP_USER=tu@gmail.com SMTP_PASS=app-password
# AWS SES: SMTP_HOST=email-smtp.region.amazonaws.com SMTP_PORT=587 SMTP_USER=xxx SMTP_PASS=xxx

# Automatizacion segura del portal DGII con Playwright
DGII_PORTAL_BASE_URL=https://dgii.gov.do
DGII_PORTAL_LOGIN_URL=https://dgii.gov.do/OFV/home.aspx
DGII_PORTAL_USERNAME=
DGII_PORTAL_PASSWORD=
DGII_PORTAL_MODE=read_only
DGII_PORTAL_ALLOWED_DOMAINS=dgii.gov.do,www.dgii.gov.do,ecf.dgii.gov.do,fc.dgii.gov.do
DGII_PORTAL_HEADLESS=true
DGII_PORTAL_BROWSER=chromium
DGII_PORTAL_BROWSER_CHANNEL=
DGII_PORTAL_TIMEOUT_MS=30000
DGII_PORTAL_NAV_TIMEOUT_MS=45000
DGII_PORTAL_ACTION_TIMEOUT_MS=20000
DGII_PORTAL_SLOW_MO_MS=0
DGII_PORTAL_DOWNLOAD_DIR=artifacts_live_dns/dgii_portal/downloads
DGII_PORTAL_EXPORT_DIR=artifacts_live_dns/dgii_portal/exports
DGII_PORTAL_AUDIT_DIR=artifacts_live_dns/dgii_portal/audit
DGII_PORTAL_SCREENSHOT_DIR=artifacts_live_dns/dgii_portal/screenshots
DGII_PORTAL_RETRY_ATTEMPTS=3
DGII_PORTAL_RETRY_BASE_DELAY=1.0
DGII_PORTAL_RETRY_MAX_DELAY=5.0
DGII_PORTAL_JSON_INDENT=2
DGII_PORTAL_CSV_ENCODING=utf-8
DGII_PORTAL_EXCEL_SHEET=DGII
DGII_PORTAL_SCREENSHOT_BLUR_RADIUS=10
DGII_PORTAL_MAX_TABLE_PAGES=10

# Catalogo local para integracion Odoo sin servicios externos
ODOO_RNC_CATALOG_PATH=integration/odoo/getupsoft_do_localization/local_rnc_directory.json

# Chatbot tenant-scoped sobre facturas/comprobantes
LLM_CHAT_ENABLED=true
LLM_PROVIDER=local
LLM_MODEL=tenant-rules-v1
LLM_API_BASE_URL=
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=20
LLM_MAX_CONTEXT_INVOICES=60
LLM_MAX_COMPLETION_TOKENS=500

JWT_SECRET=change-me
JWT_ACCESS_EXP_MINUTES=15
REFRESH_TOKEN_EXP_MINUTES=10080
MFA_ENABLED=false
COMPAT_API_ENABLED=true

# Bootstrap admin (no hardcodear claves reales en el repo)
BOOTSTRAP_ADMIN_EMAIL=admin@getupsoft.com.do
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME
BOOTSTRAP_ADMIN_ROLE=platform_admin
BOOTSTRAP_ADMIN_PHONE=0000000000
BOOTSTRAP_ADMIN_ENABLED=true

SENTRY_DSN=
SENTRY_TRACES=0.0

DGII_ENV=PRECERT
DGII_ALLOWED_HOSTS=ecf.dgii.gov.do,fc.dgii.gov.do,servicios.dgii.gov.do,eCF.dgii.gov.do

# Bases oficiales DGII (puedes sobrescribir por ambiente si DGII publica cambios)
DGII_AUTH_BASE_URL_PRECERT=https://ecf.dgii.gov.do/TesteCF/Autenticacion
DGII_AUTH_BASE_URL_CERT=https://ecf.dgii.gov.do/CerteCF/Autenticacion
DGII_AUTH_BASE_URL_PROD=https://ecf.dgii.gov.do/ecf/autenticacion

DGII_RECEPCION_BASE_URL_PRECERT=https://ecf.dgii.gov.do/TesteCF/Recepcion
DGII_RECEPCION_BASE_URL_CERT=https://ecf.dgii.gov.do/CerteCF/Recepcion
DGII_RECEPCION_BASE_URL_PROD=https://ecf.dgii.gov.do/eCF/Recepcion

DGII_RECEPCION_FC_BASE_URL_PRECERT=https://fc.dgii.gov.do/testecf/recepcionfc
DGII_RECEPCION_FC_BASE_URL_CERT=https://fc.dgii.gov.do/certecf/recepcionfc
DGII_RECEPCION_FC_BASE_URL_PROD=https://fc.dgii.gov.do/ecf/recepcionfc

DGII_CONSULTA_RESULTADO_BASE_URL_PRECERT=https://ecf.dgii.gov.do/TesteCF/ConsultaResultado
DGII_CONSULTA_RESULTADO_BASE_URL_CERT=https://ecf.dgii.gov.do/CerteCF/ConsultaResultado
DGII_CONSULTA_RESULTADO_BASE_URL_PROD=https://ecf.dgii.gov.do/eCF/ConsultaResultado

DGII_CONSULTA_ESTADO_BASE_URL_PRECERT=https://ecf.dgii.gov.do/testecf/consultaestado
DGII_CONSULTA_ESTADO_BASE_URL_PROD=https://ecf.dgii.gov.do/ecf/consultaestado

DGII_CONSULTA_TRACKIDS_BASE_URL_PRECERT=https://ecf.dgii.gov.do/testecf/consultatrackids
DGII_CONSULTA_TRACKIDS_BASE_URL_PROD=https://ecf.dgii.gov.do/ecf/consultatrackids

DGII_CONSULTA_DIRECTORIO_BASE_URL_PRECERT=https://ecf.dgii.gov.do/testecf/consultadirectorio
DGII_CONSULTA_DIRECTORIO_BASE_URL_PROD=https://ecf.dgii.gov.do/ecf/consultadirectorio

# Cliente DGII resiliente (timeouts/retries/circuit breaker)
DGII_TIMEOUT=5.0
DGII_CONN_TIMEOUT=2.0
DGII_MAX_RETRIES=3
DGII_CIRCUIT_BREAKER_THRESHOLD=5
DGII_CIRCUIT_BREAKER_WINDOW=60

# Certificado (.p12)
DGII_TOKEN_URL=
DGII_SUBMISSION_URL=
DGII_STATUS_URL=
DGII_P12_PATH=/secrets/cert.p12
DGII_P12_PASSWORD=changeit

# Compatibilidad con módulos legacy (app/core/config.py)
ENV=PRECERT
DGII_RNC=
DGII_CERT_P12_PATH=/secrets/cert.p12
DGII_CERT_P12_PASSWORD=changeit
DGII_HTTP_TIMEOUT_SECONDS=30
DGII_HTTP_RETRIES=3
JOBS_ENABLED=true
RECURRING_INVOICE_JOB_ENABLED=true
RECURRING_INVOICE_POLL_SECONDS=60

# RI / QR
RI_QR_BASE_URL=https://ri.mock/qr
