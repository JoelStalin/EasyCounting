APP_NAME=DGII e-CF API
ENVIRONMENT=development

DATABASE_URL=postgresql+asyncpg://dgii:dgii@db:5432/dgii
DB_URL=postgresql+asyncpg://dgii:dgii@db:5432/dgii
REDIS_URL=redis://redis:6379/0

CORS_ALLOW_ORIGINS=https://api.dgii.getupsoft.com.do,https://staging.dgii.getupsoft.com.do,http://localhost:8080,http://localhost:5173
RATE_LIMIT_PER_MINUTE=100

# Dominios de portales (se utilizan para CORS por defecto)
CLIENT_PORTAL_DOMAIN=cliente.getupsoft.com.do
ADMIN_PORTAL_DOMAIN=admin.getupsoft.com.do

JWT_SECRET=change-me
JWT_ACCESS_EXP_MINUTES=15
REFRESH_TOKEN_EXP_MINUTES=10080
MFA_ENABLED=false

# Bootstrap admin (no hardcodear claves reales en el repo)
BOOTSTRAP_ADMIN_EMAIL=ceo@getupsoft.local
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME
BOOTSTRAP_ADMIN_ROLE=platform_admin
BOOTSTRAP_ADMIN_PHONE=0000000000

SENTRY_DSN=
SENTRY_TRACES=0.0

DGII_ENV=PRECERT
DGII_ALLOWED_HOSTS=ecf.dgii.gov.do,fc.dgii.gov.do,servicios.dgii.gov.do,eCF.dgii.gov.do

# Bases oficiales DGII (puedes sobrescribir por ambiente si DGII publica cambios)
DGII_AUTH_BASE_URL_PRECERT=https://ecf.dgii.gov.do/TesteCF/Autenticacion
DGII_AUTH_BASE_URL_CERT=https://ecf.dgii.gov.do/CerteCF/Autenticacion
DGII_AUTH_BASE_URL_PROD=https://ecf.dgii.gov.do/ecf/autenticacion

DGII_RECEPCION_BASE_URL_PRECERT=https://ecf.dgii.gov.do/TesteCF/Recepcion
DGII_RECEPCION_BASE_URL_CERT=https://ecf.dgii.gov.do/CerteCF/Recepcion
DGII_RECEPCION_BASE_URL_PROD=https://ecf.dgii.gov.do/eCF/Recepcion

DGII_RECEPCION_FC_BASE_URL_PRECERT=https://fc.dgii.gov.do/testecf/recepcionfc
DGII_RECEPCION_FC_BASE_URL_CERT=https://fc.dgii.gov.do/certecf/recepcionfc
DGII_RECEPCION_FC_BASE_URL_PROD=https://fc.dgii.gov.do/ecf/recepcionfc

DGII_CONSULTA_RESULTADO_BASE_URL_PRECERT=https://ecf.dgii.gov.do/TesteCF/ConsultaResultado
DGII_CONSULTA_RESULTADO_BASE_URL_CERT=https://ecf.dgii.gov.do/CerteCF/ConsultaResultado
DGII_CONSULTA_RESULTADO_BASE_URL_PROD=https://ecf.dgii.gov.do/eCF/ConsultaResultado

DGII_CONSULTA_ESTADO_BASE_URL_PRECERT=https://ecf.dgii.gov.do/testecf/consultaestado
DGII_CONSULTA_ESTADO_BASE_URL_PROD=https://ecf.dgii.gov.do/ecf/consultaestado

DGII_CONSULTA_TRACKIDS_BASE_URL_PRECERT=https://ecf.dgii.gov.do/testecf/consultatrackids
DGII_CONSULTA_TRACKIDS_BASE_URL_PROD=https://ecf.dgii.gov.do/ecf/consultatrackids

DGII_CONSULTA_DIRECTORIO_BASE_URL_PRECERT=https://ecf.dgii.gov.do/testecf/consultadirectorio
DGII_CONSULTA_DIRECTORIO_BASE_URL_PROD=https://ecf.dgii.gov.do/ecf/consultadirectorio

# Cliente DGII resiliente (timeouts/retries/circuit breaker)
DGII_TIMEOUT=5.0
DGII_CONN_TIMEOUT=2.0
DGII_MAX_RETRIES=3
DGII_CIRCUIT_BREAKER_THRESHOLD=5
DGII_CIRCUIT_BREAKER_WINDOW=60

# Certificado (.p12)
DGII_TOKEN_URL=
DGII_SUBMISSION_URL=
DGII_STATUS_URL=
DGII_P12_PATH=/secrets/cert.p12
DGII_P12_PASSWORD=changeit

# Compatibilidad con módulos legacy (app/core/config.py)
ENV=PRECERT
DGII_RNC=
DGII_CERT_P12_PATH=/secrets/cert.p12
DGII_CERT_P12_PASSWORD=changeit
DGII_HTTP_TIMEOUT_SECONDS=30
DGII_HTTP_RETRIES=3
JOBS_ENABLED=true

# RI / QR
RI_QR_BASE_URL=https://ri.mock/qr
