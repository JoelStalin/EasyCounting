APP_NAME=DGII e-CF API
ENVIRONMENT=production
TZ=America/Santo_Domingo

# DB / Redis
DATABASE_URL=postgresql+asyncpg://dgii:CHANGE_ME@db:5432/dgii
REDIS_URL=redis://redis:6379/0
STORAGE_BASE_PATH=/var/getupsoft/storage
ARTIFACTS_ROOT=/app/tests/artifacts

# CORS
CORS_ALLOW_ORIGINS=https://admin.tu-dominio.do,https://app.tu-dominio.do

# Dominios de portales
APP_PORTAL_DOMAIN=app.tu-dominio.do
ADMIN_PORTAL_DOMAIN=admin.tu-dominio.do
CLIENT_PORTAL_DOMAIN=cliente.tu-dominio.do

# Seguridad (OBLIGATORIO cambiar)
JWT_SECRET=CHANGE_ME_GENERA_UNA_CLAVE_LARGA
JWT_ACCESS_EXP_MINUTES=15
REFRESH_TOKEN_EXP_MINUTES=10080
MFA_ENABLED=false
REQUEST_ID_HEADER=X-Request-ID
TRACING_HEADER=X-Trace-ID

# Bootstrap admin (OBLIGATORIO cambiar)
BOOTSTRAP_ADMIN_EMAIL=ceo@tu-dominio.do
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME
BOOTSTRAP_ADMIN_ROLE=platform_admin
BOOTSTRAP_ADMIN_PHONE=8090000000

# Observabilidad
SENTRY_DSN=
SENTRY_TRACES=0.05

# DGII
DGII_ENV=PROD
DGII_ALLOWED_HOSTS=ecf.dgii.gov.do,fc.dgii.gov.do,servicios.dgii.gov.do,eCF.dgii.gov.do

DGII_AUTH_BASE_URL_PROD=https://ecf.dgii.gov.do/ecf/autenticacion
DGII_RECEPCION_BASE_URL_PROD=https://ecf.dgii.gov.do/eCF/Recepcion
DGII_RECEPCION_FC_BASE_URL_PROD=https://fc.dgii.gov.do/ecf/recepcionfc
DGII_CONSULTA_RESULTADO_BASE_URL_PROD=https://ecf.dgii.gov.do/eCF/ConsultaResultado
DGII_CONSULTA_ESTADO_BASE_URL_PROD=https://ecf.dgii.gov.do/ecf/consultaestado
DGII_CONSULTA_TRACKIDS_BASE_URL_PROD=https://ecf.dgii.gov.do/ecf/consultatrackids
DGII_CONSULTA_DIRECTORIO_BASE_URL_PROD=https://ecf.dgii.gov.do/ecf/consultadirectorio

DGII_TIMEOUT=10.0
DGII_CONN_TIMEOUT=3.0
DGII_MAX_RETRIES=3
DGII_CIRCUIT_BREAKER_THRESHOLD=5
DGII_CIRCUIT_BREAKER_WINDOW=60

# Certificado (.p12) (OBLIGATORIO)
DGII_P12_PATH=/secrets/cert.p12
DGII_P12_PASSWORD=CHANGE_ME
DGII_BROWSER_AUTOMATION_ENABLED=false
DGII_BROWSER_AUTOMATION_MODE=evidence-only

# ENFC (certificación): exigir bearer y X509 en producción
ENFC_REQUIRE_BEARER_TOKEN=true
ENFC_TOKEN_TTL_SECONDS=900
ENFC_REQUIRE_X509_SIGNATURE=true

# Compatibilidad legacy (mantener)
ENV=PROD
DGII_CERT_P12_PATH=/secrets/cert.p12
DGII_CERT_P12_PASSWORD=CHANGE_ME
DGII_HTTP_TIMEOUT_SECONDS=30
DGII_HTTP_RETRIES=3
JOBS_ENABLED=true

# Odoo 19 JSON-2
ODOO_SYNC_ENABLED=true
ODOO_JSON2_BASE_URL=https://odoo.tu-dominio.do
ODOO_JSON2_DATABASE=CHANGE_ME
ODOO_JSON2_API_KEY=CHANGE_ME
ODOO_TIMEOUT_SECONDS=20

# RI / QR
RI_QR_BASE_URL=https://ri.tu-dominio.do/qr
